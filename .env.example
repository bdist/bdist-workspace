# Copy this file to .env and customize values for your local machine.
# These defaults are suitable for local learning environments.

# Service ports (bound to localhost in compose files)
JUPYTER_PORT=9999
REDIS_PORT=6379
POSTGRES_PORT=5432
PGADMIN_PORT=5050
APP_PORT=8080
NGROK_PORT=4040

# PostgreSQL bootstrap credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# pgAdmin login credentials
PGADMIN_DEFAULT_EMAIL=pgadmin@tecnico.pt
PGADMIN_DEFAULT_PASSWORD=pgadmin

# Flask app secret key override (docker-compose..app.yml)
FLASK_SECRET_KEY=66342083928cc29310851e51d931ea35ebb4b5747bd2a33e0d06c3d6047c83c8
